# Runtime good-game database — created by the "create" step (or run.ps1). Never commit.
good-game-database.*
*.lck

# sbt / Scala build output.
# NOTE: haunt-roll-fail/target/scala-2.13/hrf-fastopt.js is intentionally committed
# (it's the linked game) and remains tracked. This only stops *new* build cruft.
target/
project/target/
project/project/target/

# Local run/build logs (from run.ps1 or manual sbt/java runs)
good-game/*.log

# VAPID private key for Web Push — must never be committed. The PUBLIC key is embedded
# in the client (haunt-roll-fail/pwa/games.html); the private key is passed to the server
# at runtime out-of-band.
deploy/keys/

# OS junk
.DS_Store
